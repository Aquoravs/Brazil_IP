# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib
*.xdv

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/*
!.claude/state/*.example
AGENTS.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/
paper/quarto/*_files/
paper/quarto/.quarto/

# Large data files (not tracked in git)
data/raw/
data/processed/
*.qs2
*.fst
*.rds

# R pipeline output (exploratory, not paper-ready)
output/tables/

# R scripts archive
scripts/R/_archive/

# Temporary script outputs
tmp/
templates/writing-pieces/

# LaTeX build artifacts in specific folders
docs/methodology/build/
journal/meetings/**/build/
explorations/**/build/
explorations/**/output/build/
